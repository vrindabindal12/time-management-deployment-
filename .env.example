# =============================================================================
# Time Tracking – Environment / Secrets template
# =============================================================================
# Copy this file to .env (backend and/or frontend as needed) and fill in real
# values. Never commit .env or any file containing real secrets to GitHub.
#
# Option A: One file at repo root named .env (load from backend; frontend uses its own)
# Option B: backend/.env and frontend/.env.local with the variables below
# =============================================================================

# ----- Backend (Flask) – keep in backend/.env or root .env -----
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=your-secure-admin-password
DATABASE_URL=sqlite:///timetracking.db
# For PostgreSQL: postgresql://user:password@host:5432/database

FRONTEND_URL=http://localhost:3000

# Mail (for email verification)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Optional
# PORT=5000

# ----- Frontend (Next.js) – keep in frontend/.env.local -----
# Next.js only reads .env* from the frontend directory
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Production: NEXT_PUBLIC_API_URL=https://api.your-domain.com/api
